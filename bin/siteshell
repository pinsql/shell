#!/usr/bin/env bash
# siteshell — cross-platform site helper for legitimate ops (dev serve, backup, deploy hints).
# This project does NOT include or mirror malicious webshells (e.g. Gecko.php).

set -euo pipefail

PROG="$(basename "$0")"
VERSION="1.0.0"

die() { echo "$PROG: $*" >&2; exit 1; }
info() { echo "$*"; }

usage() {
  cat <<EOF
$PROG $VERSION — site management helper (Linux / macOS / Git Bash on Windows)

Usage:
  $PROG doctor              Check common tools (git, php, node, curl, rsync)
  $PROG serve [host] [port] Start PHP built-in server (default 127.0.0.1:8080)
  $PROG backup [path]       Create a timestamped .tar.gz backup of path (default: .)
  $PROG logs <file>         Follow a log file (tail -f)
  $PROG wp [...]            Run wp-cli if installed, else print install hint
  $PROG deploy-print        Show example rsync over SSH (set REMOTE_* env vars)
  $PROG version             Print version

Environment (optional, for deploy-print):
  REMOTE_USER  REMOTE_HOST  REMOTE_PATH  LOCAL_PATH (default: .)

Note: For native Windows PowerShell, use bin/siteshell.ps1
EOF
}

cmd_doctor() {
  info "=== $PROG doctor ==="
  for c in git php node npm curl rsync ssh scp; do
    if command -v "$c" >/dev/null 2>&1; then
      ver="$($c --version 2>/dev/null | head -n1 || true)"
      info "  OK  $c  ${ver:-}"
    else
      info "  --  $c  (not found)"
    fi
  done
  if command -v wp >/dev/null 2>&1; then
    info "  OK  wp  $(wp --version 2>/dev/null | head -n1 || true)"
  else
    info "  --  wp  (wp-cli not found; optional)"
  fi
  info "  cwd: $(pwd)"
  info "  disk: $(df -h . 2>/dev/null | tail -n1 || echo 'df unavailable')"
}

cmd_serve() {
  local host="${1:-127.0.0.1}"
  local port="${2:-8080}"
  command -v php >/dev/null 2>&1 || die "php not found; install PHP or use another server."
  info "PHP built-in server at http://${host}:${port}/ (Ctrl+C to stop)"
  exec php -S "${host}:${port}"
}

cmd_backup() {
  local src="${1:-.}"
  [[ -e "$src" ]] || die "path not found: $src"
  local base
  base="$(basename "$(cd "$src" && pwd)" | tr '/' '-')"
  local ts
  ts="$(date +%Y%m%d-%H%M%S)"
  local out="${base}-backup-${ts}.tar.gz"
  info "Creating archive: $out"
  tar -czf "$out" -C "$(dirname "$(cd "$src" && pwd)")" "$(basename "$(cd "$src" && pwd)")"
  info "Done: $(pwd)/$out"
}

cmd_logs() {
  local f="${1:-}"
  [[ -n "$f" ]] || die "usage: $PROG logs <file>"
  [[ -f "$f" ]] || die "not a file: $f"
  exec tail -f "$f"
}

cmd_wp() {
  if command -v wp >/dev/null 2>&1; then
    exec wp "$@"
  fi
  die "wp-cli not found. Install: https://wp-cli.org/#install"
}

cmd_deploy_print() {
  local user="${REMOTE_USER:-user}"
  local host="${REMOTE_HOST:-example.com}"
  local rpath="${REMOTE_PATH:-/var/www/html}"
  local lpath="${LOCAL_PATH:-.}"
  cat <<EOF
# Example deploy with rsync over SSH (review paths; test on a staging host first):

rsync -avz --delete \\
  --exclude '.git' --exclude 'node_modules' --exclude '.env' \\
  "${lpath}/" "${user}@${host}:${rpath}/"

# Set for this shell:
#   export REMOTE_USER=... REMOTE_HOST=... REMOTE_PATH=... LOCAL_PATH=...

# One-way pull backup from remote:
# rsync -avz "${user}@${host}:${rpath}/" "./remote-mirror/"
EOF
}

cmd_version() {
  echo "$VERSION"
}

main() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    ""|-h|--help|help) usage ;;
    doctor) cmd_doctor ;;
    serve) cmd_serve "$@" ;;
    backup) cmd_backup "$@" ;;
    logs) cmd_logs "$@" ;;
    wp) cmd_wp "$@" ;;
    deploy-print) cmd_deploy_print ;;
    version|--version) cmd_version ;;
    *) die "unknown command: $sub (try $PROG --help)" ;;
  esac
}

main "$@"
